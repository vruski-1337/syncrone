# Database Configuration
# Use either a hostname OR IP address, not both
# Examples:
#   DB_HOST=localhost
#   DB_HOST=127.0.0.1
#   DB_HOST=103.108.220.222

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=pharma_care

# Site Configuration
# Base path where the application is installed
# Examples:
#   SITE_BASE_PATH=         (for root: http://example.com/)
#   SITE_BASE_PATH=/pharma  (for subdirectory: http://example.com/pharma/)
SITE_BASE_PATH=

# SQLite Temporary Mode (for testing without MySQL/MariaDB)
# Set to 1, true, yes, or on to use SQLite instead of MySQL
USE_SQLITE_TEMP=false
TEMP_SQLITE_PATH=/tmp/pharma_care_tmp.sqlite
